# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key for brief generation.
GEMINI_API_KEY="your_gemini_api_key"

# Base URL of the app (no trailing slash). Used for magic link emails + OAuth callbacks.
# Local: http://localhost:3000 | Production: set in Railway dashboard
APP_URL="http://localhost:3000"

# Resend API key for sending magic link emails.
RESEND_API_KEY="your_resend_api_key"

# From address for all outgoing emails. Must match a verified Resend domain.
# Set to e.g. "PrepFlow <hello@mail.prepflow.app>" after domain verification.
# Falls back to onboarding@resend.dev (low deliverability) if not set.
FROM_EMAIL="PrepFlow <hello@mail.prepflow.app>"

# Google OAuth — required for "Continue with Google" sign-in.
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: https://prepflow-app-production.up.railway.app/api/auth/google/callback
# Also add http://localhost:3000/api/auth/google/callback for local dev
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── Optional ──────────────────────────────────────────────────────────────────

# Bypass key — skips rate limiting for owner testing. Set in Railway + keep secret.
BYPASS_KEY="your_bypass_key"

# ── Upcoming (add to Railway before shipping these features) ──────────────────

# ── Payments ──────────────────────────────────────────────────────────────────

# Controls which payment provider handles checkout.
# Set to "lemonsqueezy" to use Lemon Squeezy (active), "stripe" to use Stripe (once approved).
# Default: "stripe" (Stripe code is preserved, switch back when Stripe account is approved)
# PAYMENT_PROVIDER="lemonsqueezy"

# Stripe secret key — preserved for when Stripe account is approved (ADR-008).
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Lemon Squeezy — required when PAYMENT_PROVIDER=lemonsqueezy
# Create account at lemonsqueezy.com, get API key from Settings > API
# LEMONSQUEEZY_API_KEY="eyJ0..."
# LEMONSQUEEZY_STORE_ID="12345"
# LEMONSQUEEZY_WEBHOOK_SECRET="your_webhook_signing_secret"
# Product variant IDs — from Lemon Squeezy dashboard > Products > [product] > Variants
# LEMONSQUEEZY_VARIANT_ID_PRO="67890"   # $9.99/mo recurring
# LEMONSQUEEZY_VARIANT_ID_PACK="67891"  # $4.99 one-time

# PostHog analytics — both vars required, same key value.
# POSTHOG_KEY used server-side (posthog-node). VITE_POSTHOG_KEY used client-side (posthog-js, must have VITE_ prefix for Vite).
# POSTHOG_KEY="phc_..."
# VITE_POSTHOG_KEY="phc_..."
